# Juno Trading Terminal Environment Variables
# Copy this file to .env.local and fill in your actual values

## Market Data Configuration

### Finnhub API (Recommended for Stocks/ETFs)
# Get your free API key at: https://finnhub.io/register
# Free tier: 60 calls/minute, real-time US market data
FINNHUB_API_KEY=your_finnhub_api_key_here

### Alpha Vantage (Alternative)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Market Data Provider Preference
MARKET_DATA_PROVIDER=finnhub

## Google APIs (for Calendar/Gmail integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

## Redis (for caching - shared with Mission Control)
# Use the same Redis instance as Mission Control for data sync
REDIS_URL=your_upstash_redis_url_here

## Strava API (for activity tracking)
# Get your API credentials at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

## Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
